---
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/concerts', label: 'Konzerte' },
	{ href: '/heimathaus', label: 'Heimathaus' },
	{ href: '/heimathouse-concert-infos', label: 'Infos' },
];

const pathname = Astro.url.pathname;
---

<header class="site-header">
	<div class="site-header__inner">
		<a class="site-brand" href="/">Heimathouse Concerts</a>

		<nav aria-label="Hauptnavigation" class="site-nav">
			{navItems.map((item) => (
				<a
					href={item.href}
					aria-current={pathname === item.href ? 'page' : undefined}
					class:list={{ 'is-active': pathname === item.href }}
				>
					{item.label}
				</a>
			))}
		</nav>
	</div>
</header>

<style>
	.site-header {
		border-bottom: 1px solid var(--border);
		background: rgba(18, 18, 18, 0.82);
		backdrop-filter: blur(14px);
		position: sticky;
		top: 0;
		z-index: 20;
	}

	.site-header__inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 1rem 1.25rem;
		display: flex;
		gap: 1.25rem;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
	}

	.site-brand {
		font-weight: 800;
		letter-spacing: -0.05em;
		text-decoration: none;
		color: var(--text);
		font-size: 1.05rem;
		text-transform: uppercase;
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		font-size: 0.92rem;
	}

	.site-nav a {
		color: var(--text-muted);
		text-decoration: none;
		transition: color 160ms ease, opacity 160ms ease;
		position: relative;
		padding-bottom: 0.15rem;
	}

	.site-nav a:hover,
	.site-nav a.is-active {
		color: var(--text);
	}

	.site-nav a.is-active::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: -0.12rem;
		height: 1px;
		background: var(--accent-rust);
	}

	@media (max-width: 680px) {
		.site-header__inner {
			justify-content: center;
		}

		.site-brand {
			width: 100%;
			text-align: center;
		}

		.site-nav {
			justify-content: center;
		}
	}
</style>
