---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Heimathouse Concerts',
	description = 'Heimathouse Concerts: intime Abende in einem kleinen Haus mit wechselnden Bands und viel Atmosphäre.',
} = Astro.props as Props;
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#121212" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body>
		<Header />
		<main class="page-shell">
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(:root) {
		color-scheme: dark;
		--bg: #121212;
		--bg-elevated: #1e1e1e;
		--bg-soft: #191919;
		--text: #f5f3ef;
		--text-muted: #c9c5be;
		--accent-rust: #b85c38;
		--accent-green: #6a8a82;
		--border: rgba(245, 243, 239, 0.1);
		--border-strong: rgba(245, 243, 239, 0.18);
	}

	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body) {
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		line-height: 1.65;
		color: var(--text);
		background:
			radial-gradient(circle at top, rgba(184, 92, 56, 0.12), transparent 28%),
			radial-gradient(circle at 90% 0%, rgba(106, 138, 130, 0.1), transparent 25%),
			linear-gradient(180deg, #171717 0%, var(--bg) 34%, #101010 100%);
		text-rendering: optimizeLegibility;
		-webkit-font-smoothing: antialiased;
	}

	:global(*) {
		box-sizing: border-box;
	}

	:global(::selection) {
		background: rgba(184, 92, 56, 0.35);
		color: var(--text);
	}

	:global(img) {
		display: block;
		max-width: 100%;
	}

	:global(a) {
		color: inherit;
	}

	:global(h1, h2, h3) {
		font-family: 'Arial Narrow', 'Helvetica Neue Condensed', 'Inter Tight', Inter, ui-sans-serif, system-ui, sans-serif;
		letter-spacing: -0.04em;
		line-height: 0.96;
	}

	:global(main p),
	:global(main li),
	:global(main dt),
	:global(main dd) {
		color: var(--text);
	}

	:global(main .eyebrow),
	:global(main .back-link),
	:global(main .concert-detail__date),
	:global(main .section__heading span),
	:global(main .section__heading a),
	:global(main .hero__eyebrow) {
		color: var(--text-muted);
	}

	.page-shell {
		flex: 1;
		width: 100%;
		max-width: 1100px;
		margin: 0 auto;
		padding: 1.5rem 1.25rem 3.5rem;
	}

	@media (min-width: 900px) {
		.page-shell {
			padding-top: 2rem;
			padding-bottom: 4.5rem;
		}
	}

	:global(.section-title) {
		margin: 0;
		font-size: clamp(1.4rem, 2vw, 1.9rem);
	}
</style>
