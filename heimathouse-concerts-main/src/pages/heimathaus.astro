---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Heimathaus · Heimathouse Concerts" description="Mehr über den Ort und das Konzept hinter Heimathouse Concerts.">
	<section class="content-page">
		<p class="eyebrow">Heimathaus</p>
		<h1>Ein Ort für Nähe und gute Musik</h1>
		<p>
			Heimathouse Concerts steht für kleine, konzentrierte Konzertabende mit persönlicher Atmosphäre.
			Der Fokus liegt auf guter Musik, klarer Kommunikation und einem entspannten Rahmen für das Publikum.
		</p>
	</section>
</BaseLayout>

<style>
	.content-page {
		max-width: 720px;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.8rem;
	}

	h1 {
		margin: 0 0 1rem;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
	}

</style>
