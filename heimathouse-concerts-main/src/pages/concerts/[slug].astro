---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { concerts, type Concert } from '../../data/concerts';

export function getStaticPaths() {
	return concerts.map((concert) => ({
		params: { slug: concert.slug },
		props: { concert },
	}));
}

type Props = {
	concert: Concert;
};

const { concert } = Astro.props as Props;
const dateLabel = new Intl.DateTimeFormat('de-DE', {
	dateStyle: 'full',
	timeStyle: 'short',
}).format(new Date(concert.date));

const isPast = new Date(concert.date).getTime() < Date.now();
---

<BaseLayout
	title={`${concert.title} · Heimathouse Concerts`}
	description={concert.description}
>
	<article class="concert-detail">
		<a class="back-link" href="/concerts">← Zurück zur Übersicht</a>

		<div class="concert-detail__grid">
			<img src={concert.posterImage} alt={`Poster für ${concert.title}`} class="concert-detail__poster" />

			<div class="concert-detail__content">
				<p class="eyebrow">{isPast ? 'Vergangenes Konzert' : 'Kommendes Konzert'}</p>
				<h1>{concert.title}</h1>
				<p class="concert-detail__band">{concert.bandName}</p>
				<p class="concert-detail__date">{dateLabel}</p>
				<p class="concert-detail__excerpt">{concert.description}</p>
				{concert.bookingUrl && (
					<a class="concert-detail__button" href={concert.bookingUrl} target="_blank" rel="noreferrer">
						Bei Eventim buchen
					</a>
				)}
				<div class="concert-detail__content-body">
					{concert.content.map((paragraph) => <p>{paragraph}</p>)}
				</div>
			</div>
		</div>
	</article>
</BaseLayout>

<style>
	.concert-detail {
		max-width: 980px;
		margin: 0 auto;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 1.25rem;
		text-decoration: none;
	}

	.back-link:hover {
		text-decoration: underline;
	}

	.concert-detail__grid {
		display: grid;
		grid-template-columns: minmax(260px, 360px) 1fr;
		gap: 1.5rem;
		align-items: start;
	}

	.concert-detail__poster {
		width: 100%;
		border-radius: 1rem;
		object-fit: cover;
		aspect-ratio: 1 / 1;
		border: 1px solid rgba(15, 23, 42, 0.1);
	}

	.concert-detail__content {
		padding: 0.5rem 0;
	}

	.eyebrow {
		margin: 0 0 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.8rem;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3.4rem);
		line-height: 1.05;
	}

	.concert-detail__band {
		margin: 0.75rem 0 0;
		font-weight: 700;
		font-size: 1.1rem;
	}

	.concert-detail__date {
		margin: 0.2rem 0 1rem;
	}

	.concert-detail__excerpt {
		font-weight: 600;
	}

	.concert-detail__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		padding: 0.85rem 1.1rem;
		margin: 0.25rem 0 0.75rem;
		border-radius: 999px;
		background: #111827;
		color: #fff;
		text-decoration: none;
		font-weight: 700;
		transition: transform 160ms ease, background 160ms ease;
	}

	.concert-detail__button:hover {
		transform: translateY(-1px);
		background: #0f172a;
	}

	.concert-detail__content-body {
		display: grid;
		gap: 1rem;
	}

	.concert-detail__content-body p {
		max-width: 60ch;
	}

	@media (max-width: 760px) {
		.concert-detail__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
